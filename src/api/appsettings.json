{
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "<entra-tenant-id>",
    "ClientId": "<api-app-registration-client-id>",
    "ClientSecret": "<use-user-secrets-or-aca-secret>",
    "Audience": "api://<api-app-registration-client-id>"
  },
  "Sql": {
    "ConnectionString": "Server=tcp:<sql-server>.database.windows.net,1433;Database=sqldb-obo-sql-poc;Encrypt=True;TrustServerCertificate=False;Column Encryption Setting=Enabled;",
    "DatabaseScope": "https://database.windows.net/user_impersonation",
    "MaxDocumentBytes": 10485760
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Identity": "Warning"
    }
  },
  "AllowedHosts": "*"
}

