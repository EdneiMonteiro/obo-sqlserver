{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "dotnet: restore",
      "type": "process",
      "command": "dotnet",
      "args": [
        "restore",
        "OboSqlServer.sln"
      ],
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: build",
      "type": "process",
      "command": "dotnet",
      "args": [
        "build",
        "OboSqlServer.sln",
        "--configuration",
        "Debug"
      ],
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "dotnet: test",
      "type": "process",
      "command": "dotnet",
      "args": [
        "test",
        "OboSqlServer.sln",
        "--configuration",
        "Debug"
      ],
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "api: run",
      "type": "process",
      "command": "dotnet",
      "args": [
        "run",
        "--project",
        "src/api/OboSqlServer.Api.csproj"
      ],
      "isBackground": true,
      "problemMatcher": "$msCompile"
    },
    {
      "label": "bicep: build",
      "type": "shell",
      "command": "az bicep build --file infra/bicep/main.bicep",
      "problemMatcher": []
    }
  ]
}

